generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  firstName String
  rating    Float    @default(0)
  referral  String?
  deposit   Float    @default(0)
  contacts  Json
  createdAt DateTime @default(now())
}
