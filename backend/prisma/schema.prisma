generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  login         String   @unique @db.VarChar(100)
  password_hash String   @db.VarChar(255)
  role          String   @default("USER") @db.VarChar(20)
  refer_id      Int?
  is_active     Boolean  @default(false)
  created_at    DateTime @default(now()) @db.Timestamp
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamp

  // Relations
  referrer      User?    @relation("Referral", fields: [refer_id], references: [id])
  referrals     User[]   @relation("Referral")
  account       Account?

  @@index([login])
  @@index([refer_id])
}

model Account {
  id                        Int      @id
  username                  String   @unique @db.VarChar(100)
  avatar                    String?  @db.Text
  bio                       String?  @db.Text
  reputation_score          Decimal  @default(0.00) @db.Decimal(3,2)
  deals_count               Int      @default(0)
  positive_feedback_percent Int      @default(0)
  verifications             Json     @default("{}")
  created_at                DateTime @default(now()) @db.Timestamp
  updated_at                DateTime @default(now()) @updatedAt @db.Timestamp

  // Relation
  user                      User     @relation(fields: [id], references: [id], onDelete: Cascade)

  @@index([username])
  @@index([reputation_score])
}
